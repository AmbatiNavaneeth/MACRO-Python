68. Custom iterator
A custom iterator is created by implementing iter() and next() methods.
simply an iterator we create ourselves
class Counter:
    def __init__(self):
        self.num = 1
    def __iter__(self):
        return self
    def __next__(self):
        if self.num > 5:
            raise StopIteration
        value = self.num
        self.num += 1
        return value
c = Counter()
for i in c:
    print(i)

output:
1
2
3
4
5

